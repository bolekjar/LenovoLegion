# Make Intel RAPL power limit files read-only
SUBSYSTEM=="powercap", KERNEL=="intel-rapl*:0", RUN+="/bin/chmod -f 0444 $sys/$devpath/constraint_0_power_limit_uw"
SUBSYSTEM=="powercap", KERNEL=="intel-rapl*:0", RUN+="/bin/chmod -f 0444 $sys/$devpath/constraint_0_time_window_us"
SUBSYSTEM=="powercap", KERNEL=="intel-rapl*:0", RUN+="/bin/chmod -f 0444 $sys/$devpath/constraint_1_power_limit_uw"
SUBSYSTEM=="powercap", KERNEL=="intel-rapl*:0", RUN+="/bin/chmod -f 0444 $sys/$devpath/constraint_1_time_window_us"
SUBSYSTEM=="powercap", KERNEL=="intel-rapl*:0", RUN+="/bin/chmod -f 0444 $sys/$devpath/constraint_2_power_limit_uw"
SUBSYSTEM=="powercap", KERNEL=="intel-rapl*:0", RUN+="/bin/chmod -f 0444 $sys/$devpath/energy_uj"
SUBSYSTEM=="powercap", KERNEL=="intel-rapl*:0", RUN+="/bin/chmod -f 0444 $sys/$devpath/max_energy_range_uj"
SUBSYSTEM=="powercap", KERNEL=="intel-rapl*:0", RUN+="/bin/chmod -f 0444 $sys/$devpath/name"
