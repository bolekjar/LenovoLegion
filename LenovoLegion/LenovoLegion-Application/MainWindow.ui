<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1483</width>
    <height>961</height>
   </rect>
  </property>
  <property name="minimumSize">
   <size>
    <width>0</width>
    <height>0</height>
   </size>
  </property>
  <property name="maximumSize">
   <size>
    <width>16777215</width>
    <height>16777215</height>
   </size>
  </property>
  <property name="windowTitle">
   <string>Lenovo Legion Linux Toolkit</string>
  </property>
  <property name="windowIcon">
   <iconset resource="Resources.qrc">
    <normaloff>:/images/icons/LenovoLegionIco.png</normaloff>:/images/icons/LenovoLegionIco.png</iconset>
  </property>
  <property name="autoFillBackground">
   <bool>false</bool>
  </property>
  <property name="styleSheet">
   <string notr="true">/* Basic */
QWidget {
	background-color: #656565;
    border-radius: 10px;
    border: 0px;
}

QMainWindow {
	background-color: rgb(58, 59, 58);
}

/*-----QGroupBox-----*/
QGroupBox {
    border: 1px solid gray;
    border-color: #b0b0b0;
    margin-top: 10px;
    font-size: 12px;
    border-radius: 10px;
	background-color: #656565;
}

QGroupBox::title {
    subcontrol-position: top left;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
    padding: 2px 2px;
    background-color: #b0b0b0;
    color: rgb(255, 255, 255);
}

QGroupBox::indicator {
    width: 12px;
    height: 12px;
}

QGroupBox::indicator:unchecked {
    background-color: #656565;
    border: 2px solid #656565;
    border-radius: 4px;
}

QGroupBox::indicator:checked {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #656565,
        stop:1 #b0b0b0
    );
    border: 2px solid #656565;
    border-radius: 4px;
}

/*-----QPushButton-----*/
QPushButton
{
	background-color: #b0b0b0;
	color: #000000;
	border: 2px solid #888888;
	border-radius: 10px;
	padding: 8px 16px;
	font-weight: bold;
	min-width: 80px;
	text-align: center;
}


QPushButton::hover
{
	background-color: #cbccd4;
	border: 2px solid #b0b0b0;
	color: #000000;
}


QPushButton::pressed
{
	background-color: #787878;
	border: 2px solid #656565;
	color: #ffffff;
	padding-top: 9px;
	padding-bottom: 7px;
}


QPushButton::checked
{
	background-color: #787878;
	border: 2px solid #b0b0b0;
	color: #ffffff;
}


QPushButton::disabled
{
	background-color: #505050;
	border: 2px solid #404040;
	color: #888888;
}


QPushButton::focus
{
	border: 2px solid #cbccd4;
	outline: none;
}


/*-----QToolBar-----*/

QToolBar {
	background-color: #656565;
    border: 1px solid gray;
	border-radius: 0px;
}

QToolButton {
	background-color: #656565;
	margin: 0px 0px 0px 0px;
    width: 40px;
    height: 40px;
 }

QToolButton:hover {
    background-color: rgb(58, 59, 58);
}

QToolButton::checked {
    background-color: rgb(58, 59, 58);
}


/*-----QLCDNumber-----*/

QLCDNumber{
  background-color: gray;
  border: 2px solid rgb(113, 113, 113);
  border-width: 2px;
  border-radius: 10px;
  color: rgb(0, 0, 0);
}





/*-----QSlider-----*/

QSlider:horizontal {
    min-height: 28px;
}

QSlider::groove:horizontal
{
	background-color: transparent;
	height: 4px;
}


QSlider::sub-page:horizontal
{
	background-color: gray;
}


QSlider::add-page:horizontal
{
	background-color: #363535;
}


QSlider::handle:horizontal
{
	width: 25px;
    margin-top: -10px;
    margin-bottom: -10px;
    border-radius: 10px;
	background: qradialgradient(spread:reflect, cx:0.5, cy:0.5, radius:0.5, fx:0.5, fy:0.5, stop:0.6 rgba(210, 210, 210, 255), stop:0.7 rgba(210, 210, 210, 100));
}


QSlider::handle:horizontal:hover
{
	 background: qradialgradient(spread:reflect, cx:0.5, cy:0.5, radius:0.5, fx:0.5, fy:0.5, stop:0.6 rgba(255, 255, 255, 255), stop:0.7 rgba(255, 255, 255, 100));
}


QSlider::sub-page:horizontal:disabled
{
	background-color: #505050;
	border-color: #404040;
}


QSlider::add-page:horizontal:disabled
{
	background-color: #2b2b2b;
	border-color: #202020;
}


QSlider::handle:horizontal:disabled
{
	background: qradialgradient(spread:reflect, cx:0.5, cy:0.5, radius:0.5,
								fx:0.5, fy:0.5,
								stop:0.6 rgba(80, 80, 80, 255),
								stop:0.7 rgba(70, 70, 70, 100));
	border: 1px solid #404040;
}

QSlider:vertical {
    min-width: 28px;
}

QSlider::groove:vertical {
    width: 4px;
    background-color: transparent;
}

QSlider::handle:vertical {
    height: 25px;
    margin-left: -10px;
    margin-right: -10px;
    border-radius: 10px;
    background: qradialgradient(spread:reflect, cx:0.5, cy:0.5, radius:0.5, fx:0.5, fy:0.5, stop:0.6 rgba(210, 210, 210, 255), stop:0.7 rgba(210, 210, 210, 100));
}

QSlider::handle:vertical:hover {
    background: qradialgradient(spread:reflect, cx:0.5, cy:0.5, radius:0.5, fx:0.5, fy:0.5, stop:0.6 rgba(255, 255, 255, 255), stop:0.7 rgba(255, 255, 255, 100));
}

QSlider::sub-page:vertical
{
	background-color: #363535;
	margin: 4px;
}


QSlider::add-page:vertical
{
	background-color: transparent;
	background-color: gray;
}


QSlider::sub-page:vertical:disabled
{
	background-color: #2b2b2b;
	border-color: #202020;
}


QSlider::add-page:vertical:disabled
{
	background-color: #505050;
	border-color: #404040;
}


QSlider::handle:vertical:disabled
{
	background: qradialgradient(spread:reflect, cx:0.5, cy:0.5, radius:0.5,
								fx:0.5, fy:0.5,
								stop:0.6 rgba(80, 80, 80, 255),
								stop:0.7 rgba(70, 70, 70, 100));
	border: 1px solid #404040;
}





/*-----QTabWidget and QTabBar-----*/
QTabWidget {
    background-color: transparent;
}

QTabWidget::pane {
    background-color: #656565;
    border: 2px solid #888888;
    border-radius: 10px;
    top: -1px;
    padding: 5px;
}

QTabWidget::tab-bar {
    alignment: left;
}

QTabBar {
    background-color: transparent;
}

QTabBar::tab {
    background-color: #666666;
    color: #b1b1b1;
    border: 2px solid #555555;
    border-bottom: none;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
    padding: 8px 20px;
    margin-right: 3px;
    font-size: 12px;
    font-weight: normal;
}

QTabBar::tab:selected {
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:0, y2:1,
                                      stop:0 #cbccd4, stop:1 #b0b0b0);
    color: #000000;
    border: 2px solid #888888;
    border-bottom: none;
    font-weight: bold;
    padding-bottom: 10px;
}

QTabBar::tab:!selected {
    margin-top: 4px;
    background-color: #505050;
}

QTabBar::tab:!selected:hover {
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:0, y2:1,
                                      stop:0 #787878, stop:1 #656565);
    color: #ffffff;
    border: 2px solid #707070;
}

QTabBar::tab:first:!selected {
    margin-left: 0px;
}

QTabBar::tab:last {
    margin-right: 0;
}

QTabBar::tab:only-one {
    margin: 0;
}

QTabBar::tab:disabled {
    background-color: #404040;
    color: #666666;
    border: 2px solid #555555;
}

/* Vertical tabs (left/right) */
QTabBar::tab:left,
QTabBar::tab:right {
    border-top-left-radius: 0px;
    border-top-right-radius: 0px;
}

QTabBar::tab:left {
    border-left: 2px solid #888888;
    border-right: none;
    border-top-left-radius: 10px;
    border-bottom-left-radius: 10px;
    margin-bottom: 3px;
    margin-right: 0px;
}

QTabBar::tab:right {
    border-right: 2px solid #888888;
    border-left: none;
    border-top-right-radius: 10px;
    border-bottom-right-radius: 10px;
    margin-bottom: 3px;
    margin-left: 0px;
}

QTabBar::tab:left:selected,
QTabBar::tab:right:selected {
    padding-bottom: 8px;
}

/* Close button on tabs */
QTabBar::close-button {
    image: url(:/images/icons/cross.png);
    subcontrol-position: right;
    border-radius: 4px;
    background-color: transparent;
}

QTabBar::close-button:hover {
    background-color: #b0b0b0;
}

QTabBar::close-button:pressed {
    background-color: #787878;
}

/*-----QToolTip-----*/
QToolTip {
            background-color: #656565;
			background-clip: padding-box;
            color: rgb(58, 59, 58);
            border: 1px solid rgb(58, 59, 58);
            border-radius: 10px;
            padding: 10px 12px;
            font-size: 13px;
            margin: 2px;
}


/*-----QScrollBar-----*/
QScrollBar:vertical {
    border: none;
    background: #2b2b2b;
    width: 12px;
    margin: 0px 0 0px 0;
    border-radius: 6px;
}

QScrollBar::handle:vertical {
    background: #555555;
    min-height: 20px;
    border-radius: 6px;
    margin: 2px;
}

QScrollBar::handle:vertical:hover {
    background: #707070;
}

QScrollBar::handle:vertical:pressed {
    background: #888888;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    border: none;
    background: none;
    height: 0px;
}

QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}

QScrollBar:horizontal {
    border: none;
    background: #2b2b2b;
    height: 12px;
    margin: 0px 0 0px 0;
    border-radius: 6px;
}
            
QScrollBar::handle:horizontal {
    background: #555555;
    min-width: 20px;
    border-radius: 6px;
    margin: 2px;
}
            
QScrollBar::handle:horizontal:hover {
    background: #707070;
}
            
QScrollBar::handle:horizontal:pressed {
    background: #888888;
 }
            
QScrollBar::add-line:horizontal {
    border: none;
    background: none;
    height: 0px;
 }
            
QScrollBar::sub-line:horizontal {
	border: none;
	background: none;
}
            
QScrollBar::left-arrow:horizontal, QScrollBar::right-arrow:horizontal {
    border: none;
    width: 0px;
    height: 0px;
    background: none;
}
            
QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
                background: none;
}

/*-----QComboBox-----*/
QComboBox {
    background-color: #656565;
    border: 2px solid #888888;
    border-radius: 10px;
    padding: 6px 10px 6px 10px;
    min-width: 6em;
    color: #ffffff;
    font-size: 12px;
    selection-background-color: #b0b0b0;
    selection-color: #000000;
}

QComboBox:hover {
    border: 2px solid #b0b0b0;
    background-color: #707070;
}

QComboBox:focus {
    border: 2px solid #cbccd4;
    background-color: #707070;
}

QComboBox:on {
    border: 2px solid #cbccd4;
    background-color: #707070;
    padding-top: 8px;
    padding-bottom: 4px;
}

QComboBox:disabled {
    background-color: #404040;
    border: 2px solid #555555;
    color: #888888;
}

QComboBox:editable {
    background-color: #656565;
    color: #ffffff;
}

QComboBox:editable:focus {
    background-color: #707070;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: center right;
    width: 30px;
    border-left: 2px solid #888888;
    border-top-right-radius: 8px;
    border-bottom-right-radius: 8px;
    background-color: #b0b0b0;
}

QComboBox::drop-down:hover {
    background-color: #cbccd4;
}

QComboBox::drop-down:pressed {
    background-color: #787878;
}

QComboBox::drop-down:disabled {
    background-color: #555555;
    border-left: 2px solid #555555;
}

QComboBox::down-arrow {
    image: url(:/images/icons/Icons-dropdown-arrow-16.png);
    width: 12px;
    height: 12px;
}

QComboBox::down-arrow:disabled {
    image: none;
}

QComboBox::down-arrow:on {
    top: 1px;
}

QComboBox QAbstractItemView {
    background-color: transparent;
    border: none;
    padding: 0px;
    margin: 0px;
    selection-background-color: #b0b0b0;
    selection-color: #000000;
    outline: none;
}

QComboBox QAbstractItemView::item {
    padding: 6px 10px;
    margin: 0px;
    border: none;
    color: #ffffff;
    min-height: 20px;
}

QComboBox QAbstractItemView::item:selected {
    background-color: #b0b0b0;
    color: #000000;
    border-left: 4px solid #656565;
    font-weight: bold;
    font-style: italic;
}

QComboBox QAbstractItemView::item:hover {
    background-color: #787878;
    color: #ffffff;
}

QComboBox QAbstractItemView::item:selected:hover {
    background-color: #cbccd4;
    color: #000000;
    border-left: 4px solid #656565;
    font-weight: bold;
    font-style: italic;
}



/*-----QCheckBox-----*/
QCheckBox {
    spacing: 10px;
    font-size: 12px;
    color: #ffffff;
    padding: 2px;
}

QCheckBox:hover {
    color: #cbccd4;
}

QCheckBox:disabled {
    color: #888888;
}

QCheckBox::indicator {
    width: 20px;
    height: 20px;
    border-radius: 5px;
    border: 2px solid #888888;
    background-color: #656565;
}

QCheckBox::indicator:hover {
    border: 2px solid #b0b0b0;
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:0, y2:1,
                                      stop:0 #787878, stop:1 #656565);
}

QCheckBox::indicator:pressed {
    border: 2px solid #b0b0b0;
    background-color: #505050;
}

QCheckBox::indicator:checked {
    border: 2px solid #b0b0b0;
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:0, y2:1,
                                      stop:0 #cbccd4, stop:1 #b0b0b0);
    image: url(:/images/icons/Icons-checkmark-16.png);
}

QCheckBox::indicator:checked:hover {
    border: 2px solid #cbccd4;
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:0, y2:1,
                                      stop:0 #ffffff, stop:1 #cbccd4);
}

QCheckBox::indicator:checked:pressed {
    border: 2px solid #b0b0b0;
    background-color: #b0b0b0;
}

QCheckBox::indicator:unchecked:disabled {
    border: 2px solid #555555;
    background-color: #404040;
}

QCheckBox::indicator:checked:disabled {
    border: 2px solid #555555;
    background-color: #707070;
    image: url(:/images/icons/Icons-checkmark-16.png);
}

QCheckBox::indicator:indeterminate {
    border: 2px solid #b0b0b0;
    background-color: #787878;
}

QCheckBox::indicator:indeterminate:hover {
    border: 2px solid #cbccd4;
    background-color: #888888;
}



/*-----QRadioButton-----*/
QRadioButton {
    spacing: 10px;
    font-size: 12px;
    color: #ffffff;
    padding: 2px;
}

QRadioButton:hover {
    color: #cbccd4;
}

QRadioButton:disabled {
    color: #888888;
}

QRadioButton::indicator {
    width: 20px;
    height: 20px;
    border-radius: 10px;
    border: 2px solid #888888;
    background-color: #656565;
}

QRadioButton::indicator:hover {
    border: 2px solid #b0b0b0;
    background: qradialgradient(spread:pad, cx:0.5, cy:0.5, radius:0.5,
                                fx:0.5, fy:0.5,
                                stop:0 #787878,
                                stop:0.7 #656565,
                                stop:1 #505050);
}

QRadioButton::indicator:pressed {
    border: 2px solid #b0b0b0;
    background-color: #505050;
}

QRadioButton::indicator:checked {
    border: 2px solid #b0b0b0;
    background: qradialgradient(spread:pad, cx:0.5, cy:0.5, radius:0.5,
                                fx:0.5, fy:0.5,
                                stop:0 #cbccd4,
                                stop:0.3 #b0b0b0,
                                stop:0.6 #888888,
                                stop:1 #656565);
}

QRadioButton::indicator:checked:hover {
    border: 2px solid #cbccd4;
    background: qradialgradient(spread:pad, cx:0.5, cy:0.5, radius:0.5,
                                fx:0.5, fy:0.5,
                                stop:0 #ffffff,
                                stop:0.3 #cbccd4,
                                stop:0.6 #b0b0b0,
                                stop:1 #787878);
}

QRadioButton::indicator:checked:pressed {
    border: 2px solid #b0b0b0;
    background: qradialgradient(spread:pad, cx:0.5, cy:0.5, radius:0.5,
                                fx:0.5, fy:0.5,
                                stop:0 #b0b0b0,
                                stop:0.5 #888888,
                                stop:1 #656565);
}

QRadioButton::indicator:unchecked:disabled {
    border: 2px solid #555555;
    background-color: #404040;
}

QRadioButton::indicator:checked:disabled {
    border: 2px solid #555555;
    background: qradialgradient(spread:pad, cx:0.5, cy:0.5, radius:0.5,
                                fx:0.5, fy:0.5,
                                stop:0 #707070,
                                stop:0.5 #555555,
                                stop:1 #404040);
}

/*-----QLineEdit-----*/
QLineEdit {
    background-color: #656565;
    border: 2px solid #888888;
    border-radius: 10px;
    padding: 6px 10px;
    color: #ffffff;
    selection-background-color: #b0b0b0;
    selection-color: #000000;
    font-size: 12px;
}

QLineEdit:hover {
    border: 2px solid #b0b0b0;
    background-color: #707070;
}

QLineEdit:focus {
    border: 2px solid #cbccd4;
    background-color: #707070;
    outline: none;
}

QLineEdit:disabled {
    background-color: #404040;
    border: 2px solid #555555;
    color: #888888;
}

QLineEdit[readOnly=&quot;true&quot;] {
    background-color: #585858;
    border: 2px solid #707070;
    color: #b0b0b0;
}

/*-----QSpinBox-----*/
QSpinBox {
    background-color: #656565;
    border: 2px solid #888888;
    border-radius: 10px;
    padding: 6px;
    color: #ffffff;
    selection-background-color: #b0b0b0;
    selection-color: #000000;
    font-size: 12px;
}

QSpinBox:hover {
    border: 2px solid #b0b0b0;
    background-color: #707070;
}

QSpinBox:focus {
    border: 2px solid #cbccd4;
    background-color: #707070;
}

QSpinBox:disabled {
    background-color: #404040;
    border: 2px solid #555555;
    color: #888888;
}

QSpinBox::up-button {
    subcontrol-origin: border;
    subcontrol-position: top right;
    width: 20px;
    border-left: 2px solid #888888;
    border-top-right-radius: 8px;
    background-color: #b0b0b0;
}

QSpinBox::up-button:hover {
    background-color: #cbccd4;
}

QSpinBox::up-button:pressed {
    background-color: #787878;
}

QSpinBox::up-button:disabled {
    background-color: #555555;
}

QSpinBox::up-arrow {
    image: url(:/images/icons/Icons-dropup-arrow-16.png);
    width: 10px;
    height: 10px;
}

QSpinBox::up-arrow:disabled {
    image: none;
}

QSpinBox::down-button {
    subcontrol-origin: border;
    subcontrol-position: bottom right;
    width: 20px;
    border-left: 2px solid #888888;
    border-bottom-right-radius: 8px;
    background-color: #b0b0b0;
}

QSpinBox::down-button:hover {
    background-color: #cbccd4;
}

QSpinBox::down-button:pressed {
    background-color: #787878;
}

QSpinBox::down-button:disabled {
    background-color: #555555;
}

QSpinBox::down-arrow {
    image: url(:/images/icons/Icons-dropdown-arrow-16.png);
    width: 10px;
    height: 10px;
}

QSpinBox::down-arrow:disabled {
    image: none;
}

/*-----QDoubleSpinBox-----*/
QDoubleSpinBox {
    background-color: #656565;
    border: 2px solid #888888;
    border-radius: 10px;
    padding: 6px;
    color: #ffffff;
    selection-background-color: #b0b0b0;
    selection-color: #000000;
    font-size: 12px;
}

QDoubleSpinBox:hover {
    border: 2px solid #b0b0b0;
    background-color: #707070;
}

QDoubleSpinBox:focus {
    border: 2px solid #cbccd4;
    background-color: #707070;
}

QDoubleSpinBox:disabled {
    background-color: #404040;
    border: 2px solid #555555;
    color: #888888;
}

QDoubleSpinBox::up-button {
    subcontrol-origin: border;
    subcontrol-position: top right;
    width: 20px;
    border-left: 2px solid #888888;
    border-top-right-radius: 8px;
    background-color: #b0b0b0;
}

QDoubleSpinBox::up-button:hover {
    background-color: #cbccd4;
}

QDoubleSpinBox::up-button:pressed {
    background-color: #787878;
}

QDoubleSpinBox::up-button:disabled {
    background-color: #555555;
}

QDoubleSpinBox::up-arrow {
    image: url(:/images/icons/Icons-dropup-arrow-16.png);
    width: 10px;
    height: 10px;
}

QDoubleSpinBox::up-arrow:disabled {
    image: none;
}

QDoubleSpinBox::down-button {
    subcontrol-origin: border;
    subcontrol-position: bottom right;
    width: 20px;
    border-left: 2px solid #888888;
    border-bottom-right-radius: 8px;
    background-color: #b0b0b0;
}

QDoubleSpinBox::down-button:hover {
    background-color: #cbccd4;
}

QDoubleSpinBox::down-button:pressed {
    background-color: #787878;
}

QDoubleSpinBox::down-button:disabled {
    background-color: #555555;
}

QDoubleSpinBox::down-arrow {
    image: url(:/images/icons/Icons-dropdown-arrow-16.png);
    width: 10px;
    height: 10px;
}

QDoubleSpinBox::down-arrow:disabled {
    image: none;
}</string>
